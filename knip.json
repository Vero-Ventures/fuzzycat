{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "app/**/*.{ts,tsx}",
    "components/**/*.{ts,tsx}",
    "lib/**/*.{ts,tsx}",
    "server/**/*.ts",
    "scripts/*.ts",
    "e2e/**/*.ts",
    "tests/**/*.ts",
    "*.test.ts"
  ],
  "project": ["**/*.{ts,tsx}"],
  "ignore": ["drizzle.config.ts", "scripts/qa-local.ts"],
  "ignoreBinaries": [
    "gitleaks",
    "semgrep",
    "tsc",
    "biome",
    "madge",
    "knip",
    "type-coverage",
    "license-checker-rseidelsohn",
    "playwright",
    "drizzle-kit",
    "next"
  ],
  "drizzle": false,
  "ignoreDependencies": [
    "@commitlint/cli",
    "@next/env",
    "postcss",
    "shadcn",
    "tw-animate-css",
    "react-dom",
    "@biomejs/biome",
    "@stoplight/spectral-cli",
    "@types/react-dom",
    "drizzle-kit",
    "license-checker-rseidelsohn",
    "madge",
    "type-coverage"
  ]
}
